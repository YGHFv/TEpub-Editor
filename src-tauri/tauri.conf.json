{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TEpub-Editor",
  "version": "0.4.5",
  "identifier": "com.tepubeditor.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "TEpub-Editor-TXT",
        "label": "main",
        "width": 1200,
        "height": 740,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob:; font-src 'self' blob:; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "txt"
        ],
        "name": "Text File",
        "description": "用 TEpub-Editor 打开文本文件",
        "role": "Editor"
      },
      {
        "ext": [
          "epub"
        ],
        "name": "EPUB File",
        "description": "用 TEpub-Editor 打开 EPUB 文件",
        "role": "Editor"
      }
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
